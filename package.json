{
  "name": "sessvm",
  "version": "2.0.0",
  "description": "Server-owned session management library.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "files": [
    "CHANGELOG.md",
    "LICENSE-GPL-3.0",
    "LICENSE-LGPL-3.0",
    "dist",
    "client"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./client/refresh.d.ts",
      "default": "./client/refresh.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test:runtime": "node --test tests/runtime.test.js tests/client.test.mjs",
    "test": "npm run typecheck && npm run test:runtime",
    "prepack": "npm run clean && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/radiiplus/sessvm.git"
  },
  "keywords": [
    "session",
    "authentication",
    "typescript",
    "security",
    "csrf",
    "fingerprinting",
    "nodejs",
    "jwt",
    "server-owned"
  ],
  "author": "radiiplus",
  "license": "LGPL-3.0-only OR GPL-3.0-only",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.6.0"
  }
}
